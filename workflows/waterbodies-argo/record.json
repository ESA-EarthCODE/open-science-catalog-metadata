{
  "id": "waterbodies-argo",
  "type": "Feature",
  "geometry": null,
  "properties": {
    "title": "Water bodies workflow adapted to Argo Workflows",
    "created": "2025-12-16T11:18:12Z",
    "osc:project": "ospd",
    "description": "This workflow accepts STAC items referencing GeoTIF assets and determines areas of water in the data based on NDWI (Normalised Difference Water Index) and the Otsu Threshold. The workflow is defined as an OGC Application Package using Common Workflow Language (CWL) so the executing platform will need to support CWL execution. It generates a STAC Catalog as output, linking to the individual STAC items generated during the workflow execution. This version of the workflow is a cross-platform experiment for OSPD in which the original waterbodies workflow has been ported to Argo Workflows. As part of this, experimental provenance data has been added to this record.",
    "keywords": [
      "water",
      "NDWI",
      "water bodies",
      "otsu",
      "eoepca"
    ],
    "contacts": [
      {
        "name": "Tom Jellicoe",
        "positionName": "Software Developer",
        "organization": "Telespazio UK",
        "emails": [
          {
            "value": "thomas.jellicoe@telespazio.com"
          }
        ]
      }
    ],
    "type": "workflow",
    "resourceLanguages": [],
    "externalIds": [],
    "formats": [],
    "language": {
      "code": "en-GB",
      "name": "English (Great Britain)"
    },
    "languages": [],
    "osc-prov:type": [
      "Entity",
      "Plan",
      "Workflow",
      "EOApplicationPackage"
    ],
    "osc-prov:generatedBy": "https://esa-earthcode.github.io/open-science-catalog-metadata/projects/ospd/collection.json",
    "osc-prov:hasInput": {
      "aoi": {
        "title": "area of interest",
        "description": "area of interest as a bounding box",
        "schema": {
          "type": "string",
          "default": "-121.399,39.834,-120.74,40.472",
          "pattern": "^-?\\d+(\\.\\d+)?,-?\\d+(\\.\\d+)?, -?\\d+(\\.\\d+)?,-?\\d+(\\.\\d+)?$"
        }
      },
      "epsg": {
        "title": "EPSG code",
        "description": "EPSG code",
        "schema": {
          "type": "string",
          "default": "EPSG:4326"
        }
      },
      "stac_items": {
        "title": "Sentinel-2 STAC items",
        "description": "list of Sentinel-2 COG STAC items",
        "schema": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "minItems": 1
        },
        "default": [
          "https://earth-search.aws.element84.com/v0/collections/sentinel-s2-l2a-cogs/items/S2B_10TFK_20210713_0_L2A",
          "https://earth-search.aws.element84.com/v0/collections/sentinel-s2-l2a-cogs/items/S2A_10TFK_20220524_0_L2A"
        ]
      },
      "bands": {
        "title": "bands used for the NDWI",
        "description": "bands used for the NDWI",
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "maxItems": 2,
          "default": [
            "green",
            "nir"
          ]
        }
      }
    },
    "osc-prov:hasOutput": {
      "stac_catalog": {
        "title": "STAC Catalog",
        "description": "STAC Catalog containing the water bodies results",
        "osc-prov:type": [
          "Collection",
          "Entity"
        ],
        "schema": {
          "type": "string",
          "format": "uri"
        }
      }
    }
